{
	"name": "@beautiful-code/string-utils",
	"version": "1.0.0",
	"description": "String manipulation and case-conversion utilities (camel, kebab, snake, readable) with a chainable stream API",
	"author": "Chris Coppola <mynamereallysux@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/MyNameReallySux/beautiful-code-monorepo.git",
		"directory": "packages/string-utils"
	},
	"keywords": [
		"string",
		"case-conversion",
		"camelcase",
		"kebab-case",
		"snake-case",
		"utils"
	],
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist"
	],
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@beautiful-code/type-utils": "workspace:^"
	}
}
