{
	"name": "@beautiful-code/type-utils",
	"version": "0.1.6",
	"description": "Runtime type identification and validation utilities with TypeScript type guards",
	"author": "Chris Coppola <mynamereallysux@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/MyNameReallySux/beautiful-code-monorepo.git",
		"directory": "packages/type-utils"
	},
	"keywords": [
		"typescript",
		"type-guards",
		"validation",
		"utils"
	],
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist"
	],
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit"
	}
}
